{
  "schemaVersion": 1,
  "id": "kindreds",
  "version": "${version}",
  "name": "Kindreds of Middle-earth",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.kindreds.Kindreds"
    ],
    "client": [
      "com.kindreds.KindredsClient"
    ],
    "fabric-client-gametest": [
      "com.kindreds.client.gametest.UiScreenshotTest",
      "com.kindreds.client.gametest.KindredsFunctionalTest",
      "com.kindreds.client.gametest.AbilityVisualTest",
      "com.kindreds.client.gametest.ContextEffectTest",
      "com.kindreds.client.gametest.ScreenIterationTest"
    ]
  },
  "mixins": [
    "kindreds.mixins.json",
    {
      "config": "kindreds.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.8",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "middle-earth": "*"
  }
}